# 이 파일을 .env 로 복사한 뒤 값을 채우세요:  cp .env.example .env

# === Claude (두뇌) — 필수 ===
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# === 사용자 프로필 (생활 교정에 사용) ===
JARVIS_USER_NAME=호차
JARVIS_TIMEZONE=Asia/Seoul
# 자비스가 부를 호칭/말투 (예: "편하게 반말", "정중하게")
JARVIS_PERSONA=따뜻하지만 솔직하게, 군더더기 없이 핵심만. 반말.

# === 웨이크워드 ===
# 기본 제공 모델로 시작. 커스텀 "자비스" 모델을 만들면 경로를 넣으세요.
# 예) secrets/jarvis.onnx  (scripts/train_wakeword.md 참고)
JARVIS_WAKEWORD_MODEL=hey_jarvis
JARVIS_WAKEWORD_THRESHOLD=0.5

# === STT (faster-whisper) ===
# tiny / base / small / medium / large-v3  (파이면 base, PC면 small~medium)
JARVIS_WHISPER_MODEL=small
# cpu / cuda
JARVIS_WHISPER_DEVICE=cpu
# int8 (CPU 권장) / float16 (GPU)
JARVIS_WHISPER_COMPUTE=int8

# === TTS (Piper) ===
# 한국어 음성 모델 경로 (scripts/setup_voices.md 에서 다운로드)
JARVIS_PIPER_VOICE=secrets/voices/ko_KR-glados-medium.onnx

# === Google Calendar ===
# OAuth 클라이언트 시크릿 JSON 경로 (scripts/setup_google.md 참고)
JARVIS_GOOGLE_CLIENT_SECRET=secrets/google_client_secret.json
JARVIS_GOOGLE_TOKEN=secrets/google_token.json
# 읽을 캘린더 ID (기본: 주 캘린더)
JARVIS_CALENDAR_ID=primary
